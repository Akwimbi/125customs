generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int       @id @default(autoincrement())
  email              String    @unique
  passwordHash       String    @map("password_hash")
  role               String    @default("customer")
  audienceType       String    @default("both") @map("audience_type")
  companyName        String?   @map("company_name")
  contactPerson      String?   @map("contact_person")
  kraPin             String?   @map("kra_pin")
  agpoCertNumber     String?   @map("agpo_cert_number")
  taxComplianceValid DateTime?   @map("tax_compliance_valid")
  occasionTags       String[]  @default([]) @map("occasion_tags")
  giftMessageEnabled   Boolean   @default(false) @map("gift_message_enabled")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  name                 String
  carts                Cart[]
  orders               Order[]
  quotes               Quote[]

  @@index([audienceType], map: "user_audience_type_idx")
  @@index([role], map: "user_role_idx")
  @@map("users")
}

model Product {
  id                     Int             @id @default(autoincrement())
  name                   String
  description            String
  basePrice              Decimal         @map("base_price") @db.Decimal(10, 2)
  audienceType           String          @default("both") @map("audience_type")
  category               String
  customizable           Boolean         @default(true)
  bulkDiscountThresholds Json?           @map("bulk_discount_thresholds")
  imageUrl               String?         @map("image_url")
  galleryUrls            String[]        @default([]) @map("gallery_urls")
  occasionTags           String[]        @default([]) @map("occasion_tags")
  giftMessageEnabled     Boolean         @default(false) @map("gift_message_enabled")
  isActive               Boolean         @default(true) @map("is_active")
  stockQuantity          Int             @default(0) @map("stock_quantity")
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")
  CartItem               CartItem[]
  orderItems             OrderItem[]
  options                ProductOption[]
  quoteItems             QuoteItem[]

  @@index([audienceType], map: "product_audience_type_idx")
  @@index([category], map: "product_category_idx")
  @@index([isActive], map: "product_is_active_idx")
  @@index([audienceType, category, isActive], map: "product_audience_category_active_idx")
  @@index([name], map: "product_name_idx")
  @@map("products")
}

model ProductOption {
  id              Int      @id @default(autoincrement())
  productId       Int      @map("product_id")
  optionName      String   @map("option_name")
  optionValue     String   @map("option_value")
  priceAdjustment Decimal  @default(0) @map("price_adjustment") @db.Decimal(10, 2)
  materialType    String?  @map("material_type")
  materialDensity Decimal? @map("material_density") @db.Decimal(10, 4)
  laserPasses     Int      @default(1) @map("laser_passes")
  lengthMm        Decimal? @map("length_mm") @db.Decimal(10, 2)
  widthMm         Decimal? @map("width_mm") @db.Decimal(10, 2)
  heightMm        Decimal? @map("height_mm") @db.Decimal(10, 2)
  thicknessMm     Decimal? @map("thickness_mm") @db.Decimal(10, 2)
  weightGrams     Decimal? @map("weight_grams") @db.Decimal(10, 2)
  isBulkSubstrate Boolean  @default(false) @map("is_bulk_substrate")
  product         Product  @relation(fields: [productId], references: [id])

  @@index([productId], map: "product_option_product_id_idx")
  @@index([optionName], map: "product_option_name_idx")
  @@unique([productId, optionName, optionValue])
  @@map("product_options")
}

model Order {
  id                  Int                  @id @default(autoincrement())
  orderNumber         String               @unique @map("order_number")
  userId              Int?                 @map("user_id")
  audienceType        String               @default("b2c") @map("audience_type")
  customerName        String               @map("customer_name")
  customerEmail       String               @map("customer_email")
  customerPhone       String               @map("customer_phone")
  companyName         String?              @map("company_name")
  poNumber            String?              @map("po_number")
  giftMessage         String?              @map("gift_message")
  occasion            String?              @map("occasion")
  shippingMethod      String               @default("pickup_mtaani") @map("shipping_method")
  pickupLocation      String?              @map("pickup_location")
  pickupPhone         String?              @map("pickup_phone")
  totalAmount         Decimal              @map("total_amount") @db.Decimal(10, 2)
  status              String               @default("pending")
  paymentReference    String?              @map("payment_reference")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  items               OrderItem[]
  user                User?                @relation(fields: [userId], references: [id])
  PaystackTransaction PaystackTransaction?

  @@index([userId], map: "order_user_id_idx")
  @@index([status], map: "order_status_idx")
  @@index([createdAt], map: "order_created_at_idx")
  @@index([userId, status], map: "order_user_status_idx")
  @@map("orders")
}

model OrderItem {
  id                   Int      @id @default(autoincrement())
  orderId              Int      @map("order_id")
  productId            Int      @map("product_id")
  quantity             Int
  unitPrice            Decimal  @map("unit_price") @db.Decimal(10, 2)
  subtotal             Decimal  @db.Decimal(10, 2)
  customizationDetails Json?    @map("customization_details")
  selectedOptions      String[] @default([]) @map("selected_options")
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product              Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId], map: "order_item_order_id_idx")
  @@index([productId], map: "order_item_product_id_idx")
  @@map("order_items")
}

model Quote {
  id                 Int         @id @default(autoincrement())
  quoteNumber        String      @unique @map("quote_number")
  userId             Int?        @map("user_id")
  status             String      @default("pending")
  companyName        String      @map("company_name")
  contactPerson      String      @map("contact_person")
  email              String
  phone              String
  projectDescription String      @map("project_description")
  quantity           Int
  materialPreference String?     @map("material_preference")
  serializationType  String?     @map("serialization_type")
  serializationData  String?     @map("serialization_data")
  agpoCertNumber     String?     @map("agpo_cert_number")
  kraPin             String?     @map("kra_pin")
  taxComplianceValid DateTime?   @map("tax_compliance_valid")
  compliancePackUrl  String?     @map("compliance_pack_url")
  totalAmount        Decimal?    @map("total_amount") @db.Decimal(10, 2)
  notes              String?
  validUntil         DateTime    @map("valid_until")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")
  items              QuoteItem[]
  user               User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId], map: "quote_user_id_idx")
  @@index([status], map: "quote_status_idx")
  @@index([createdAt], map: "quote_created_at_idx")
  @@index([userId, status], map: "quote_user_status_idx")
  @@map("quotes")
}

model QuoteItem {
  id        Int     @id @default(autoincrement())
  quoteId   Int     @map("quote_id")
  productId Int     @map("product_id")
  quantity  Int
  unitPrice Decimal @map("unit_price") @db.Decimal(10, 2)
  subtotal  Decimal @db.Decimal(10, 2)
  product   Product @relation(fields: [productId], references: [id])
  quote     Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId], map: "quote_item_quote_id_idx")
  @@index([productId], map: "quote_item_product_id_idx")
  @@map("quote_items")
}

model Cart {
  id          Int        @id @default(autoincrement())
  sessionId   String     @unique @map("session_id")
  userId      Int?       @map("user_id")
  isB2B       Boolean    @default(false) @map("is_b2b")
  companyName String?    @map("company_name")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  items       CartItem[]
  user        User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([sessionId], map: "cart_session_id_idx")
  @@index([userId], map: "cart_user_id_idx")
  @@map("carts")
}

model CartItem {
  id                  Int      @id @default(autoincrement())
  cartId              Int      @map("cart_id")
  productId           Int      @map("product_id")
  quantity            Int
  customizationDetails Json?    @map("customization_details")
  selectedOptions     String[] @default([]) @map("selected_options")
  cart                Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product             Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([cartId], map: "cart_item_cart_id_idx")
  @@index([productId], map: "cart_item_product_id_idx")
  @@map("cart_items")
}

model PaystackTransaction {
  id        Int       @id @default(autoincrement())
  orderId   Int       @unique @map("order_id")
  reference String    @unique
  amount    Decimal   @db.Decimal(10, 2)
  channel   String?
  status    String
  paidAt    DateTime? @map("paid_at")
  createdAt DateTime  @default(now()) @map("created_at")
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "paystack_transaction_order_id_idx")
  @@map("paystack_transactions")
}

