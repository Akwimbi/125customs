DATABASE_URL="postgresql://postgres:postgres@localhost:5432/125customs?schema=public"

# Server
PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET="125customs-secret-key-change-in-production"

# Paystack (Payment Gateway)
PAYSTACK_SECRET_KEY="sk_test_xxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxx"
PAYSTACK_WEBHOOK_SECRET="whsec_xxxxx"

# Resend (Transactional Email)
RESEND_API_KEY="re_xxxxx"

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# Admin Credentials (for initial setup)
ADMIN_EMAIL="admin@125customs.co.ke"
ADMIN_PASSWORD="admin123"

# WhatsApp Business (Optional)
WHATSAPP_PHONE="+254712345678"

# Pickup Mtaani (Shipping)
PICKUP_MTAANI_FEE=120
PICKUP_LOCATIONS="Nairobi CBD, Mombasa Road, Ngong Road, Thika Road"

# Logging
LOG_LEVEL="info"
